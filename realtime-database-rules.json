{
  "rules": {
    "orders": {
      ".read": "auth != null && ((auth.token.email == 'unlimitedtopup001@gmail.com' || auth.token.email == 'vishnubangaru001@gmail.com') || (query.orderByChild == 'uid' && query.equalTo == auth.uid))",
      ".write": "auth != null",
      ".indexOn": ["uid"]
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
